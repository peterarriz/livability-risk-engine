# Frontend
# URL of the FastAPI backend. Required for the Next.js demo to fetch live scores.
# Leave unset to run the frontend in demo-data mode (no backend needed).
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# Backend — live scoring mode
# Set POSTGRES_HOST to activate the real scoring path in backend/app/main.py.
# When unset, the /score endpoint returns the approved mocked demo response.
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_DB=livability
POSTGRES_USER=postgres
POSTGRES_PASSWORD=

# Backend — Clerk auth
# Required when using Clerk-protected endpoints such as /auth/sync and /keys.
# Development issuers often look like: https://<instance>.clerk.accounts.dev
# Production should use the Clerk production Frontend API URL.
CLERK_ALLOWED_ISSUERS=
# Optional single-issuer fallback if CLERK_ALLOWED_ISSUERS is unset:
# CLERK_ISSUER=https://<instance>.clerk.accounts.dev

# Backend - internal admin endpoints
# Required for /admin/*, /debug/score, and /health/db.
ADMIN_SECRET=

# Backend — CORS
# Override the allowed frontend origin in production deployments.
# Defaults to localhost:3000 when unset.
FRONTEND_ORIGIN=
