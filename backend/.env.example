# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real credentials.

# Railway Postgres connection string (find it in Railway → Postgres card → Connect tab)
DATABASE_URL=postgresql://postgres:PASSWORD@HOST.railway.app:PORT/railway

# Optional: allow your deployed frontend to call the API
# FRONTEND_ORIGIN=https://your-app.vercel.app

# Clerk auth for /auth/sync and /keys
# Development issuers often look like: https://<instance>.clerk.accounts.dev
# Production should use the Clerk production Frontend API URL.
CLERK_ALLOWED_ISSUERS=
# Optional single-issuer fallback if CLERK_ALLOWED_ISSUERS is unset:
# CLERK_ISSUER=https://<instance>.clerk.accounts.dev
