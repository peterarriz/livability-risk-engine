# frontend/.env.example
# tasks: app-024, app-025
#
# Required environment variables for the Next.js frontend.
# Copy this file to .env.local and fill in values for local development.
# In production (Vercel), set these in the Vercel dashboard — do NOT commit .env.local.

# ---------------------------------------------------------------------------
# Clerk authentication (app-024)
# Get these from https://dashboard.clerk.com → your app → API Keys
# ---------------------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Note: CLERK_SECRET_KEY must also be set in Railway (backend) for /keys JWT verification (app-025)

# Clerk redirect URLs (defaults work for most setups)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# ---------------------------------------------------------------------------
# Backend API
# ---------------------------------------------------------------------------
# FastAPI base URL — Railway deployment URL in production, localhost for dev
NEXT_PUBLIC_API_URL=

# ---------------------------------------------------------------------------
# NextAuth (legacy — kept for existing OAuth flows)
# ---------------------------------------------------------------------------
NEXTAUTH_SECRET=
NEXTAUTH_URL=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
